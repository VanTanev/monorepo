{
  "extends": "@monorepo/config/tsconfig.base.json",
  "compilerOptions": {
    "types": ["node", "jest"],
    "lib": ["dom", "dom.iterable", "esnext"],
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "*.mjs"
  ],
  "exclude": ["node_modules"]
}
