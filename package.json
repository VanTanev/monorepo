{
  "name": "monorepo",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">= 22.0.0"
  },
  "scripts": {
    "build": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint",
    "ci": "turbo run test:types lint test --concurrency=50%",
    "dev": "pnpm run -r dev",
    "test:types": "turbo test:types",
    "format": "prettier --write .",
    "prepare": "lefthook install",
    "sherif": "sherif",
    "postinstall": "preconstruct dev",
    "knip": "knip"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "neverBuiltDependencies": [],
    "allowedDeprecatedVersions": {
      "eslint": "8"
    }
  },
  "preconstruct": {
    "packages": [
      "packages/*",
      "!packages/config"
    ],
    "___experimentalFlags_WILL_CHANGE_IN_PATCH": {
      "typeModule": true,
      "distInRoot": true,
      "importsConditions": true
    }
  },
  "devDependencies": {
    "@preconstruct/cli": "2.8.12",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/node": "22.19.17",
    "knip": "6.4.1",
    "lefthook": "2.1.6",
    "prettier": "3.8.3",
    "pretty-quick": "4.2.2",
    "sherif": "1.11.1",
    "turbo": "2.9.6",
    "typescript": "6.0.3"
  }
}
